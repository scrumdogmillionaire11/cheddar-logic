# ----------------------------------
# cheddarlogic.com Environment
# ----------------------------------

APP_NAME=cheddarlogic
APP_ENV=local
PUBLIC_DOMAIN=http://localhost:3000

# ----------------------------------
# Database
# ----------------------------------
# CHEDDAR_DB_PATH is the canonical SQLite database path (single source of truth)
# Used by web, worker, and scheduler processes
# Production: set explicit persistent path (recommended: /opt/data/cheddar-prod.db)
# Alternative: set CHEDDAR_DATA_DIR for auto-discovery
# Auto-discovery: scans directory for databases with card_payloads, prefers -prod in name
# Local dev default lives under /tmp; production must use a persistent path
CHEDDAR_DB_PATH=/tmp/cheddar-logic/cheddar.db

# FPL Sage database path (separate from main Cheddar DB)
# Optional: Only required if using FPL Sage integration
# If not set, FPL corruption checks are skipped (backward compatible)
# Production: /opt/data/fpl_snapshots.sqlite
# Local dev: cheddar-fpl-sage/db/fpl_snapshots.sqlite (relative to repo root)
# CHEDDAR_FPL_DB_PATH=/opt/data/fpl_snapshots.sqlite

# **DEPRECATED** - Remove these from production config (causes DB_PATH_CONFLICT error)
# These legacy variables are actively unset by scripts/start-scheduler.sh and removed by scripts/consolidate-record-db.sh
# DATABASE_URL=postgresql://cheddar:cheddar@localhost:5432/cheddarlogic

# ----------------------------------
# Ingestion Providers
# ----------------------------------
ODDS_PROVIDER=
ODDS_API_KEY=
ODDS_BASE_URL=
SPORTS=NBA,NHL,NFL,MLB,NCAAM,SOCCER,FPL

# ----------------------------------
# FPL Sage API
# ----------------------------------
# Server-side rewrite destination for /api/v1 routes (Next.js)
FPL_API_BASE_URL=http://localhost:8000/api/v1
# Dev-only browser override. Do not set in production.
NEXT_PUBLIC_FPL_API_URL=http://localhost:8000/api/v1

# ----------------------------------
# Logging
# ----------------------------------
LOG_LEVEL=INFO

# ----------------------------------
# Optional Caching
# ----------------------------------
REDIS_URL=redis://localhost:6379/0

# ----------------------------------
# Web Configuration
# ----------------------------------
API_BASE_URL=http://localhost:3000
NEXT_PUBLIC_PUBLIC_DOMAIN=http://localhost:3000
NEXT_PUBLIC_API_BASE_URL=http://localhost:3000
NEXT_PUBLIC_ENABLE_PLAYER_PROPS=false
NEXT_PUBLIC_ENABLE_WELCOME_HOME=true
# Verbose cards debug trace (dev only)
NEXT_PUBLIC_CARDS_TRACE_VERBOSE=false
# Include recently started games in /api/games during dev (off by default)
ENABLE_DEV_PAST_GAMES=false
# How far back to include when ENABLE_DEV_PAST_GAMES=true
DEV_GAMES_LOOKBACK_HOURS=24

# ----------------------------------
# Admin API
# ----------------------------------
# Admin API secret for /api/admin/* routes (required in production)
# Generate: openssl rand -hex 32
ADMIN_API_SECRET=

# ----------------------------------
# Auth (Phase 1 magic link)
# ----------------------------------
# REQUIRED in production — set a strong random value, e.g.: openssl rand -hex 32
# In production, missing or default value causes an immediate AUTH_SECRET_MISCONFIGURED error.
AUTH_SECRET=replace-with-strong-random-secret
# Development token generator allowlist for /api/auth/token.
# NODE_ENV=development bypasses this allowlist for local use.
# In every other environment, leave this empty to disable the route or set a
# comma-separated exact client IP allowlist such as 127.0.0.1,10.0.0.5.
TOKEN_ROUTE_ALLOWED_IPS=

# ----------------------------------
# API Security Feature Flags
# ----------------------------------
# Optional: set to "false" to disable in non-production environments
ENABLE_AUDIT_LOGGING=true
ENABLE_RBAC=true

# Time-to-live values in milliseconds
AUTH_MAGIC_LINK_TTL_MS=900000           # 15 minutes
AUTH_ACCESS_TTL_MS=86400000             # 24 hours (was 15min - this was causing login loops!)
AUTH_REFRESH_TTL_MS=2592000000          # 30 days

# DEV ONLY: Bypass auth for easier local development (set to any email or leave empty)
# WARNING: Never enable this in production!
DEV_BYPASS_AUTH_EMAIL=
NEXT_PUBLIC_DEV_BYPASS_ENABLED=        # Set to "true" to show dev bypass banner on /login
# ----------------------------------
# Worker Scheduler Configuration
# ----------------------------------
# Tick loop interval (milliseconds, default 60000 = 1 minute)
TICK_MS=60000

# Dry run mode (true = log only, no execution)
DRY_RUN=false

# Timezone for fixed-time windows (09:00, 12:00)
# Node convention: TZ env var (not TIMEZONE)
TZ=America/New_York

# Enable fixed-time catchup on scheduler restart
# If true (default), fixed windows run immediately if past due today
# If false, fixed windows only run when clock crosses them (dev mode)
FIXED_CATCHUP=true

# Discord card snapshots (09:00, 12:00, 18:00 ET)
# Production-safe defaults: disabled until explicitly enabled and webhook URL set.
ENABLE_DISCORD_CARD_WEBHOOKS=false
DISCORD_CARD_WEBHOOK_URL=
# Optional payload controls (safe defaults)
DISCORD_CARD_WEBHOOK_CHAR_LIMIT=1800
DISCORD_CARD_WEBHOOK_MAX_ROWS=120
# Market allow-list (CSV): only these market tags appear in snapshot (e.g. TOTAL,ML,1P,SHOTS,PROP,POTD)
# If unset, all markets are included.
DISCORD_CARD_WEBHOOK_MARKETS=
# Market deny-list (CSV, no allow-list required): e.g. SHOTS
# When allow-list is set, deny-list is ignored.
DISCORD_CARD_WEBHOOK_MARKETS_DENY=
# Sport allow-list (CSV): e.g. NHL,NBA — if unset, all sports included
DISCORD_CARD_WEBHOOK_SPORTS=
# Bucket allow-list (CSV): official,lean,pass_blocked — if unset, all buckets included
DISCORD_CARD_WEBHOOK_BUCKETS=
# Include POTD play-of-the-day in snapshot (default false)
DISCORD_INCLUDE_POTD_IN_SNAPSHOT=false
# Discord 429 resilience: max retry_after before failing fast (ms), total send budget (ms)
DISCORD_MAX_RETRY_AFTER_MS=5000
TOTAL_DISCORD_TIMEOUT_MS=10000

# POTD engine
# Alert webhook for no-pick notifications (unset = silent)
DISCORD_ALERT_WEBHOOK_URL=
# POTD Play of the Day Discord webhook
DISCORD_POTD_WEBHOOK_URL=

# Season gate: disable models for off-season sports to avoid wasted runs
# MLB: re-enable ~March 20 when regular season starts (spring training games don't matter for betting)
# NFL: re-enable ~September 1 when regular season starts
# NCAAM: March Madness runs through ~April 7

# Enable/disable individual jobs
# IMPORTANT: Keep ENABLE_ODDS_PULL=false in local dev (hard gate in pull_odds_hourly.js throws
# if APP_ENV=local and this is true). Only set true in production.
ENABLE_ODDS_PULL=false
# Token quota safety: monthly limit (paid tier = 20000), reserve % to hold back, 401 cooldown
# EMERGENCY: set to actual remaining balance when rolling over mid-month.
# Normal full-tier value is 20000. Current April 2026 emergency value: 2000.
ODDS_MONTHLY_LIMIT=2000
ODDS_BUDGET_RESERVE_PCT=15
ODDS_401_COOLDOWN_MS=7200000
# Conservative main odds baseline: 09:00/12:00/15:00/18:00/21:00 ET
# 180 = 8 fetches/day (32 tokens). Use 120 for normal operation (48 tokens/day).
ODDS_FETCH_SLOT_MINUTES=180
ODDS_FETCH_START_HOUR=9
# Health watchdog should not alert between the expected 3-hour pulls
ODDS_GAP_ALERT_MINUTES=210
# Backstop refresh is opt-in only; leave disabled unless intentionally tightening freshness
ENABLE_ODDS_BACKSTOP=false
ENABLE_NHL_MODEL=true
ENABLE_NBA_MODEL=true
ENABLE_NCAAM_MODEL=true
ENABLE_MLB_MODEL=false
ENABLE_NFL_MODEL=false
ENABLE_WELCOME_HOME=true
ENABLE_SOCCER_XG_MODEL=false

# Rollout flags (operator-controlled, default-safe)
# Keep these false by default; enable only during controlled rollout windows.
# Phase 2: threshold routing (odds-backed decision strictness by market/sport)
ENABLE_MARKET_THRESHOLDS_V2=false
# Phase 3: CLV telemetry ledger (additive telemetry only; does not alter settlement outcomes)
ENABLE_CLV_LEDGER=false

# Settlement scheduling
# ENABLE_SETTLEMENT gates all settlement jobs
ENABLE_SETTLEMENT=true
# Hourly sweep runs once per hour during first N minutes (default 5)
ENABLE_HOURLY_SETTLEMENT_SWEEP=true
SETTLEMENT_HOURLY_BOUNDARY_MINUTES=5
# Hourly card settlement is strict by default; set true in dev to backfill display-log from payloads
SETTLEMENT_HOURLY_ENABLE_DISPLAY_BACKFILL=false
# Nightly (02:00 ET) card settlement is also strict by default
SETTLEMENT_NIGHTLY_ENABLE_DISPLAY_BACKFILL=false
# Global safety gate: even when hourly/nightly backfill toggle is true, payload backfill runs only when this is true.
# Keep false in production to ensure settlement remains strictly tied to actual /cards display_log rows.
CHEDDAR_SETTLEMENT_ENABLE_DISPLAY_BACKFILL=false
# Optional NCAAM fallback when ESPN has no safe match
SETTLEMENT_ENABLE_SPORTSREF_FALLBACK=false
# HTTP timeout (ms) for Sports Reference date-page fetches
SPORTSREF_REQUEST_TIMEOUT_MS=15000

# NCAAM FT% Integration (TeamRankings CSV fallback for ESPN)
# Gate: enable/disable the entire refresh pipeline for NCAAM FT% CSV
ENABLE_NCAAM_FT_REFRESH=true
# Max age (minutes) before CSV is considered stale and needs refresh
# Default 360 (6 hours) ensures refresh happens at 09:00 ET if last run was overnight
NCAAM_FT_REFRESH_MAX_AGE_MINUTES=360
# CSV file path (must be writable by worker process)
# Default: data/input/teamrankings_ncaam_ft_pct.csv
# Production: /opt/data/teamrankings_ncaam_ft_pct.csv (align with other data artifacts)
TEAMRANKINGS_NCAAM_FT_CSV_PATH=/opt/data/teamrankings_ncaam_ft_pct.csv
# TeamRankings source URL (fallback if not provided)
TEAMRANKINGS_NCAAM_FT_URL=https://www.teamrankings.com/ncaa-basketball/stat/free-throw-pct

# NHL player shots ingest
# Scheduler gate for daily 04:00 ET tracked-player sync job (default: disabled — set to "true" to opt in)
# ENABLE_NHL_SOG_PLAYER_SYNC=true
# Number of NHL shooters to track (ranked by shots per game, min games filter applied)
NHL_SOG_TOP_SHOOTERS_COUNT=50
# Minimum games played for tracked-player eligibility
NHL_SOG_MIN_GAMES_PLAYED=20
# Optional season override for NHL stats sync (default auto-derives current season, e.g. 20252026)
# NHL_SOG_SEASON_ID=20252026
# Fallback manual ID list (used only when tracked_players has no active rows)
NHL_SOG_PLAYER_IDS=[8478402,8477492]
# Rate limit between NHL API calls (ms)
NHL_SOG_SLEEP_MS=500

# NHL player blocked shots ingest
# Scheduler gate for daily 09:00 ET BLK ingest window (sync + pull from internal logs).
# Defaults to enabled — set false to suspend BLK data collection without touching card output.
ENABLE_NHL_BLK_INGEST=true
# WI-1197/WI-1198: external BLK CSV ingestion was decommissioned.
# BLK model inputs now rely on internal logs and recency windows.
# Enable BLK card generation from run_nhl_player_shots_model.
# Cards use synthetic lines derived from model projections (l5BlkMean * 2, rounded to nearest 0.5).
# No bookmaker line comparison — projection-only output, consistent with NO_ODDS repo policy.
NHL_BLK_CARDS_ENABLED=true

# NHL player shots stays projection-only for now.
# Live Odds API prop pulls and NHL 1P odds pulls were removed in WI-0727.

# MLB pitcher K and MLB F5 stay projection-only for now.
# Odds-backed pitcher prop pulls and F5 odds ingestion were removed in WI-0727.
MLB_K_PROPS=SHADOW
NHL_PROPS=OFF

# NHL 1P Phase-2: market-aware fair probability output (WI-0505)
# 1P cards remain projection-only. This flag only affects internal fair-prob math.
# Rollback: set to false and redeploy — no DB migration or schema change needed.
NHL_1P_FAIR_PROB_PHASE2=false
# Normal CDF sigma parameter for 1P fair probability (spec range: 1.22–1.30, default midpoint).
NHL_1P_SIGMA=1.26

# FPL disabled by default until deadline-based scheduler implemented
# (Currently uses game-time windows which is incorrect for FPL)
ENABLE_FPL_MODEL=false

# SQLite database path (CANONICAL SOURCE OF TRUTH)
# Use ONLY CHEDDAR_DB_PATH - do not set DATABASE_PATH or RECORD_DATABASE_PATH
CHEDDAR_DB_PATH=/tmp/cheddar-logic/cheddar.db
# Alternative: set CHEDDAR_DATA_DIR and it will auto-discover databases:
#   1. Scans directory for .db files with card_payloads table
#   2. Prefers databases with -prod in the filename (e.g., cheddar-prod.db)
#   3. Falls back to first database with card_payloads
#   4. Falls back to {dir}/cheddar.db if none found
# CHEDDAR_DATA_DIR=/opt/data
