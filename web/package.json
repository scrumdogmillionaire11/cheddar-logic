{
  "name": "web",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "next dev --turbo",
    "build": "next build --webpack && node scripts/copy-native-bindings.cjs",
    "start": "next start",
    "lint": "eslint",
    "test:api:cards:security": "node --import tsx/esm src/__tests__/api-cards-gameId-security.test.js",
    "test:dedupe": "node src/__tests__/api-dedupe.test.js",
    "test:cards-sport-filter": "node src/__tests__/api-cards-sport-filter.test.js",
    "test:cards-lifecycle-regression": "node src/__tests__/api-cards-lifecycle-regression.test.js",
    "test:cards:projection-exclusion": "node src/__tests__/cards-projection-exclusion.test.js",
    "test:db-mutating": "npm run test:dedupe && npm run test:games-filter && npm run test:cards-sport-filter && npm run test:cards-lifecycle-regression",
    "test:api:nhl-contract": "node src/__tests__/api-nhl-payload-contract.test.js",
    "test:games-filter": "node src/__tests__/api-games-filter.test.js",
    "test:filters": "node --import tsx/esm src/__tests__/game-card-filters.test.js && node --import tsx/esm src/__tests__/game-card-filters-play-first.test.js && node --import tsx/esm src/__tests__/filters-pass-play-main-view-regression.test.js",
    "test:card-decision": "tsx src/__tests__/game-card-decision.test.js",
    "test:driver-roles": "tsx src/__tests__/driver-roles-completeness.test.js",
    "test:filters:play-first": "node --import tsx/esm src/__tests__/game-card-filters-play-first.test.js",
    "test:transform:sport": "node src/__tests__/game-card-transform-sport.test.js",
    "test:transform:truth-price": "node src/__tests__/game-card-transform-truth-price.test.js",
    "test:transform:market": "node src/__tests__/game-card-transform-market-contract.test.js",
    "test:transform:total-bias": "node src/__tests__/game-card-transform-total-bias-contract.test.js",
    "test:transform:evidence": "node src/__tests__/game-card-transform-evidence-contract.test.js",
    "test:ui:cards": "node src/__tests__/ui-cards-smoke.test.js",
    "test:ui:results": "node src/__tests__/ui-results-smoke.test.js",
    "test:ui:evidence": "node src/__tests__/ui-evidence-no-play-contract.test.js",
    "test:api:games:market": "node src/__tests__/api-games-market-smoke.test.js",
    "test:api:games:repair-budget": "node src/__tests__/api-games-repair-budget.test.js",
    "test:api:results:decision-segmentation": "node src/__tests__/api-results-decision-segmentation.test.js",
    "test:api:results:flags": "node src/__tests__/api-results-flags.test.js",
    "test:api:results:projection-split": "node --import tsx/esm src/__tests__/api-results-projection-split.test.js",
    "test:api:results:sport-filter": "node --import tsx/esm src/__tests__/api-results-sport-filter.test.js",
    "test:decision:canonical": "node src/__tests__/canonical-play-decision.test.js",
    "test:filters:presets": "node src/__tests__/filters-presets-contract.test.js",
    "test:ci:smoke": "npm run test:ui:results && npm run test:api:games:market && npm run test:api:games:repair-budget && npm run test:api:nhl-contract && npm run test:api:results:decision-segmentation"
  },
  "dependencies": {
    "@cheddar-logic/data": "file:../packages/data",
    "@cheddar-logic/models": "file:../packages/models",
    "next": "16.2.1",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "resend": "^6.9.3"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.1.3",
    "tailwindcss": "^4",
    "tsx": "^4.21.0",
    "typescript": "^5"
  },
  "optionalDependencies": {
    "better-sqlite3": "^12.8.0"
  }
}
