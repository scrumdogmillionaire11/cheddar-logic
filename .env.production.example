# Copy to /opt/cheddar-logic/.env.production on the Pi
# Fill in real values for secrets

# ----------------------------------
# Core Environment
# ----------------------------------
NODE_ENV=production
PORT=3000
TZ=America/New_York
DRY_RUN=false

# ----------------------------------
# Database
# ----------------------------------
# CRITICAL: Use ONLY CHEDDAR_DB_PATH as the single source of truth.
# Do NOT set DATABASE_PATH, RECORD_DATABASE_PATH, or DATABASE_URL.
# Setting multiple paths will cause "Conflicting explicit DB paths" error.
# Path must match ReadWritePaths in service files.
CHEDDAR_DB_PATH=/opt/data/cheddar-prod.db
CHEDDAR_DB_AUTODISCOVER=false
# DB lock retry timeout for the worker process.
# When the web server holds the lock, the worker retries for up to this many ms
# (100ms intervals) before failing. Set to 0 on the web server (default).
# Recommended: 10000 (10s) for the worker service.
CHEDDAR_DB_LOCK_TIMEOUT_MS=0

# ----------------------------------
# API Keys & Credentials
# ----------------------------------
ODDS_API_KEY=<your_key>
RESEND_API_KEY=<your_key>
# REQUIRED in production — set a strong random value, e.g.: openssl rand -hex 32
# Missing or default value causes AUTH_SECRET_MISCONFIGURED error on token creation/verification.
AUTH_SECRET=<generate-with-openssl-rand-hex-32>
DEV_BYPASS_AUTH_EMAIL=

# ----------------------------------
# Web & Frontend
# ----------------------------------
# FPL Sage FastAPI runs locally on the Pi — do NOT use api.cheddarlogic.com
# next.config.ts reads this at build time to set the rewrite target
FPL_API_BASE_URL=http://localhost:8000/api/v1
NEXT_PUBLIC_ENABLE_PLAYER_PROPS=true

# ----------------------------------
# Worker & Scheduler Configuration
# ----------------------------------
TICK_MS=60000
FIXED_CATCHUP=true
ENABLE_PIPELINE_HEALTH_WATCHDOG=true
PIPELINE_HEALTH_ALERT_CONSECUTIVE=4
CARDS_FRESHNESS_MAX_AGE_MINUTES=45

# ----------------------------------
# Odds API Configuration
# ----------------------------------
ENABLE_ODDS_PULL=true
ODDS_FETCH_SLOT_MINUTES=60
ODDS_FETCH_START_HOUR=7
ODDS_MONTHLY_LIMIT=20000
ODDS_BUDGET_RESERVE_PCT=10
ENABLE_ODDS_BACKSTOP=false
SPORTS=NBA,NHL,NFL,MLB

# ==================================================
# SPORT CONFIGURATION
# ==================================================

# ----------------------------------
# NHL (National Hockey League)
# ----------------------------------
ENABLE_NHL_MODEL=true
NHL_SOG_PROP_EVENTS_ENABLED=false      # Fetch real SOG odds per-event
NHL_BLK_PROP_EVENTS_ENABLED=false      # Fetch real BLK odds per-event
NHL_BLK_CARDS_ENABLED=true            # Generate BLK cards
NHL_SOG_CARDS_ENABLED=true            # Generate SOG cards
NHL_1P_FAIR_PROB_PHASE2=true          # Enhanced 1P probability calculation
NHL_1P_ODDS_ENABLED=true              # Fetch 1P odds (pull_nhl_1p_odds job)

# ----------------------------------
# MLB (Major League Baseball)
# ----------------------------------
ENABLE_MLB_MODEL=true
MLB_PITCHER_K_PROP_EVENTS_ENABLED=true
# PITCHER_KS_MODEL_MODE is intentionally disabled in code (hard-locked to PROJECTION_ONLY)
# Setting this env var has NO effect — see resolvePitcherKsMode() in run_mlb_model.js
# PITCHER_KS_MODEL_MODE=ODDS_BACKED

# ----------------------------------
# NBA (National Basketball Association)
# ----------------------------------
ENABLE_NBA_MODEL=true

# ----------------------------------
# NFL (National Football League)
# ----------------------------------
# Season gate: re-enable ~September 1 when regular season starts
ENABLE_NFL_MODEL=false

# ----------------------------------
# NCAAM (College Basketball)
# ----------------------------------
# Season gate: March Madness runs through ~April 7
ENABLE_NCAAM_MODEL=false

# ----------------------------------
# FPL (Fantasy Premier League)
# ----------------------------------
# Disabled by default until deadline-based scheduler implemented
# (Currently uses game-time windows which is incorrect for FPL)
ENABLE_FPL_MODEL=false

# ==================================================
# OPTIONAL FEATURES
# ==================================================

# ----------------------------------
# Discord Webhooks & Card Posting
# ----------------------------------
# Card snapshots (09:00, 12:00, 18:00 ET)
ENABLE_DISCORD_CARD_WEBHOOKS=false
# Fallback — used for any sport that has no dedicated channel below
DISCORD_CARD_WEBHOOK_URL=
# Per-sport channels (optional) — set URL to route that sport to its own Discord channel
DISCORD_CARD_WEBHOOK_URL_NHL=
DISCORD_CARD_WEBHOOK_URL_NBA=
DISCORD_CARD_WEBHOOK_URL_MLB=
DISCORD_CARD_WEBHOOK_CHAR_LIMIT=1800
DISCORD_CARD_WEBHOOK_MAX_ROWS=120

# ----------------------------------
# CLV (Closing Line Value) Ledger
# ----------------------------------
ENABLE_CLV_LEDGER=true

# ----------------------------------
# POTD (Play of the Day)
# ----------------------------------
ENABLE_POTD=true
DISCORD_POTD_WEBHOOK_URL=
POTD_STARTING_BANKROLL=100
ENABLE_WELCOME_HOME=false
NEXT_PUBLIC_ENABLE_WELCOME_HOME=false
