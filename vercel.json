{
  "version": 2,
  "buildCommand": "npm install --prefix packages/data && bash scripts/init-db-vercel.sh && cd web && npm install && npm run build",
  "outputDirectory": "web/.next",
  "framework": "nextjs",
  "installCommand": "npm install --prefix web && npm install --prefix packages/data",
  "devCommand": "npm run dev --prefix web",
  "ignoreCommand": "git diff --quiet HEAD^ HEAD ./web",
  "headers": [
    {
      "source": "/(.*)\\.html$",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=0, must-revalidate"
        }
      ]
    },
    {
      "source": "/static/chunks/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    {
      "source": "/static/media/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    }
  ],
  "routes": [
    {
      "src": "/favicon\\.ico",
      "dest": "/favicon.ico",
      "headers": {
        "Cache-Control": "public, max-age=31536000, immutable"
      },
      "continue": true
    }
  ],
  "git": {
    "deploymentEnabled": {
      "main": true
    }
  }
}
