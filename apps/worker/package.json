{
  "name": "cheddar-worker",
  "version": "1.0.0",
  "description": "Worker jobs for cheddar-logic: odds fetching, model runs, etc.",
  "main": "src/index.js",
  "scripts": {
    "job:pull-odds": "node src/jobs/pull_odds_hourly.js",
    "job:check-odds-health": "node src/jobs/check_odds_health.js",
    "job:pull-odds:test": "node -e \"require('./src/jobs/pull_odds_hourly.js').pullOddsHourly().then(console.log).catch(console.error)\"",
    "job:pull-schedule-ncaam": "node src/jobs/pull_schedule_ncaam.js",
    "job:pull-schedule-nhl": "node src/jobs/pull_schedule_nhl.js",
    "job:pull-nhl-player-shots": "node src/jobs/pull_nhl_player_shots.js",
    "job:run-nhl-player-shots-model": "node src/jobs/run_nhl_player_shots_model.js",
    "job:pull-schedule-nba": "node src/jobs/pull_schedule_nba.js",
    "job:run-nhl-model": "node src/jobs/run_nhl_model.js",
    "job:run-nhl-model:test": "node -e \"require('./src/jobs/run_nhl_model.js').runNHLModel().then(console.log).catch(console.error)\"",
    "job:run-nba-model": "node src/jobs/run_nba_model.js",
    "job:run-nba-model:test": "node -e \"require('./src/jobs/run_nba_model.js').runNBAModel().then(console.log).catch(console.error)\"",
    "job:run-fpl-model": "node src/jobs/run_fpl_model.js",
    "job:run-fpl-model:test": "node -e \"require('./src/jobs/run_fpl_model.js').runFPLModel().then(console.log).catch(console.error)\"",
    "job:run-nfl-model": "node src/jobs/run_nfl_model.js",
    "job:run-nfl-model:test": "node -e \"require('./src/jobs/run_nfl_model.js').runNFLModel().then(console.log).catch(console.error)\"",
    "job:run-mlb-model": "node src/jobs/run_mlb_model.js",
    "job:run-mlb-model:test": "node -e \"require('./src/jobs/run_mlb_model.js').runMLBModel().then(console.log).catch(console.error)\"",
    "job:run-soccer-model": "node src/jobs/run_soccer_model.js",
    "job:run-soccer-model:test": "node -e \"require('./src/jobs/run_soccer_model.js').runSoccerModel().then(console.log).catch(console.error)\"",
    "job:run-ncaam-model": "node src/jobs/run_ncaam_model.js",
    "job:run-ncaam-model:test": "node -e \"require('./src/jobs/run_ncaam_model.js').runNCAAMModel().then(console.log).catch(console.error)\"",
    "job:refresh-ncaam-ft-csv": "node src/jobs/refresh_ncaam_ft_csv.js",
    "job:backfill-card-results": "node src/jobs/backfill_card_results.js",
    "job:backfill-card-results:dry-run": "node src/jobs/backfill_card_results.js --dry-run",
    "job:settle-games": "node src/jobs/settle_game_results.js",
    "job:settle-cards": "node src/jobs/settle_pending_cards.js",
    "job:settlement-report": "node src/jobs/report_settlement_health.js",
    "db:backup": "node -e \"require('./src/utils/db-backup.js').backupDatabase('manual')\"",
    "db:backups": "node src/utils/list-backups.js",
    "db:restore": "node src/utils/restore-backup.js",
    "job:resettle-history": "node src/jobs/resettle_historical_cards.js",
    "job:resettle-history:dry-run": "node src/jobs/resettle_historical_cards.js --dry-run",
    "job:import-historical-settled": "node src/jobs/import_historical_settled_results.js --apply",
    "job:import-historical-settled:dry-run": "node src/jobs/import_historical_settled_results.js --dry-run",
    "job:dev-refresh": "node src/jobs/pull_odds_hourly.js && node src/jobs/run_nhl_model.js && node src/jobs/run_nba_model.js && node src/jobs/run_ncaam_model.js && node src/jobs/run_soccer_model.js",
    "scheduler": "node src/schedulers/main.js",
    "scheduler:dev": "ENABLE_ODDS_PULL=true ENABLE_NHL_MODEL=true node src/schedulers/main.js",
    "test": "jest",
    "test:pipeline:nhl": "jest src/jobs/__tests__/pipeline_nhl_idempotency.test.js",
    "test:scheduler:windows": "node src/__tests__/scheduler-windows.test.js",
    "test:pipeline:settlement": "node src/__tests__/settlement-pipeline-integration.test.js",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "deployment:verify": "node ../../scripts/deployment-verify.js"
  },
  "keywords": [
    "worker",
    "jobs",
    "scheduler"
  ],
  "license": "ISC",
  "dependencies": {
    "@cheddar-logic/adapters": "file:../../packages/adapters",
    "@cheddar-logic/data": "file:../../packages/data",
    "@cheddar-logic/models": "file:../../packages/models",
    "@cheddar-logic/odds": "file:../../packages/odds",
    "cheerio": "^1.0.0-rc.12",
    "dotenv": "^16.4.5",
    "luxon": "^3.7.2",
    "uuid": "^9.0.0"
  },
  "devDependencies": {
    "jest": "^29.7.0",
    "sqlite3": "^5.1.7"
  },
  "overrides": {
    "@tootallnate/once": "3.0.1",
    "http-proxy-agent": "7.0.2",
    "tar": "7.5.10",
    "cacache": "20.0.3",
    "make-fetch-happen": "15.0.4",
    "node-gyp": "12.2.0"
  }
}
